# EditorConfig — https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 4

[*.conf]
indent_size = 4

[*.toml]
indent_size = 4

[*.ini]
indent_size = 4
