# Membrane Environment Configuration
# Copy this file to .env and fill in the values.

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
MEMBRANE_LOG_LEVEL=INFO

# Redis connection URL (used by server and persistence backend)
# Format: redis://[:password@]host[:port][/db]
MEMBRANE_REDIS_URL=redis://localhost:6379/0

# Unique identifier for this Membrane node
MEMBRANE_NODE_ID=membrane-0

# Transport protocol: http or grpc
MEMBRANE_TRANSPORT=http

# Compute backend: cpu, gpu, ollama, openai, anthropic, transformers
MEMBRANE_COMPUTE=cpu

# Server listen port
MEMBRANE_PORT=8080

# Server bind host
MEMBRANE_HOST=0.0.0.0

# LLM API key (required when using openai or anthropic compute backends)
# MEMBRANE_LLM_API_KEY=

# LLM API base URL (for OpenAI-compatible endpoints)
# MEMBRANE_LLM_BASE_URL=

# Ollama server URL (for ollama compute backend)
# MEMBRANE_OLLAMA_URL=http://localhost:11434

# Maximum number of concurrent workers
# MEMBRANE_MAX_WORKERS=4

# Redis password (if authentication is required)
# MEMBRANE_REDIS_PASSWORD=

# Log file path (optional, logs to stdout by default)
# MEMBRANE_LOG_FILE=
